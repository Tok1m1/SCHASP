# =============================================================================
# SCHASP — репозиторий для демонстрации приложения (Backend + Frontend)
# =============================================================================

# --- Зависимости ---
node_modules/

# --- Вне scope репозитория (только приложение) ---
scripts/
diploma/
диплом/

# --- Черновики и временные файлы в корне ---
tmp_*
ref_headings*.txt

# --- Сборка / кэш (dist и uploads коммитим для демо) ---
Frontend/.vite/
.vite/
*.tsbuildinfo

# --- Логи и отладка ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Тесты и покрытие ---
coverage/
.nyc_output/
.jest/

# --- ОС ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- IDE / редактор ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Cursor (локальные настройки среды, не часть демо) ---
.cursor/

# --- Прочее ---
*.local

# .env намеренно НЕ игнорируется — демо-конфиг с тестовыми значениями
# Frontend/dist/ и Backend/uploads/ намеренно НЕ игнорируются — для демо без сборки
